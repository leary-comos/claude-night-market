{
  "hooks": {
    "SessionStart": [
      {
        "_comment": "Order 1: Detect git platform (GitHub/GitLab) early so other hooks can use it",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/detect-git-platform.sh",
            "timeout": 1
          }
        ]
      },
      {
        "_comment": "Order 2: Check if anthropics/claude-code is starred; prompt user if not",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/auto-star-repo.sh",
            "timeout": 3
          }
        ]
      },
      {
        "_comment": "Order 3: Fetch recent discussions (depends on git platform detection above)",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/fetch-recent-discussions.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "_comment": "Block inline lint suppression directives (noqa, type: ignore, eslint-disable, etc.)",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/noqa_guard.py",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "WebFetch|WebSearch|Bash",
        "_comment": "Sanitize external content for prompt injection and code execution patterns",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/sanitize_external_content.py",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
