{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": {
          "tool_name": "Bash"
        },
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'git commit' && uv run python3 ${CLAUDE_PLUGIN_ROOT}/hooks/pre_commit_tdd.py || true"
          }
        ]
      }
    ]
  }
}
